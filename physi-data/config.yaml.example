# LLM 提供商配置
llm:
  provider: "minimax"               # minimax / anthropic / openai
  model: "MiniMax-M2.7"             # 模型型号
  api_key: "your-api-key-here"      # API Key
  base_url: ""                       # 留空使用默认

# 感知层（默认可关，先跑通主程序再开）
perception:
  screenpipe:
    enabled: false
    api_url: "http://localhost:3030"
  activitywatch:
    enabled: false
    api_url: "http://localhost:5600"
  clipboard:
    enabled: true
    poll_interval: 5                 # 秒

# IoT
iot:
  enabled: false
  url: "http://homeassistant.local:8123"
  token: "your-ha-long-lived-token"

# QQ（使用 NapCat 时再填真实号码）
qq:
  ws_url: "ws://localhost:3001"
  owner_qq: "1000000001"
  talk_qq:
    - "1000000002"

# Agent 行为
agent:
  segment_interval: 1800            # 30 分钟 (秒)
  user_trigger_cooldown: 600        # 10 分钟节流 (秒)
  confirm_dangerous: true           # 高危操作是否需确认

# 隐私
privacy:
  redact_sensitive: false            # 本地部署默认不过滤/不脱敏
  ignore_apps:                       # 不监控的应用列表
    - "KeePass"
    - "1Password"
  sensitive_keywords: []             # 开启脱敏时才会使用

# Monitor UI
monitor:
  enabled: true
  host: "127.0.0.1"
  port: 8765
